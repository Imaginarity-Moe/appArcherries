Options -Indexes

# Sensible Dateien schützen
<FilesMatch "^\.env|^\.htaccess|\.sql$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # SPA-Fallback NUR für Nicht-/api/-Pfade. Die Ausnahme als RewriteCond
    # direkt in der Rule ist zuverlässiger als ein separates "^api/ - [L]"
    # (mod_rewrite ignoriert das [L] manchmal bei No-Op-Targets in .htaccess).
    RewriteCond %{REQUEST_URI} !^/api(/|$)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # index.html + Service-Worker + Manifest: NIE cachen — sonst zeigt der Browser
    # nach einem Deploy weiter die alten Bundle-Hash-Verweise.
    <FilesMatch "^(index\.html|sw\.js|registerSW\.js|manifest\.webmanifest|workbox-[A-Za-z0-9]+\.js)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # Vite-Hash-Assets (foo-<hash>.{js,css}) und Fonts sind immutable — 1 Jahr.
    <FilesMatch "-[A-Za-z0-9_-]{6,}\.(js|css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.woff2$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # PWA-/Apple-Icons: kurze Cache-Lebensdauer + must-revalidate, damit
    # iOS Safari nach einem Deploy nicht ewig am alten Icon klebt. In der
    # index.html werden die Hrefs zusätzlich per build-time-Hash versioniert
    # (?v=<rev>) — beides zusammen knackt den iOS-Apple-Touch-Cache zuverlässig.
    <FilesMatch "^(apple-touch-icon|favicon-32x32|pwa-192x192|pwa-512x512|pwa-maskable-512x512)\.png$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
</IfModule>
