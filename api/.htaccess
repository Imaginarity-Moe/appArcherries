RewriteEngine On

# Sensible Dateien nie ausliefern
<FilesMatch "\.(sql|md|json|lock|env)$">
    Require all denied
</FilesMatch>
<FilesMatch "^(composer\.(json|lock)|\.env.*)$">
    Require all denied
</FilesMatch>

# composer-vendor und migrations niemals direkt erreichbar
RedirectMatch 403 ^/api/vendor(/|$)
RedirectMatch 403 ^/api/migrations(/|$)
RedirectMatch 403 ^/api/lib(/|$)
RedirectMatch 403 ^/api/routes(/|$)

# Frontcontroller: alles auf index.php (ausser existierende Dateien)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L,QSA]
