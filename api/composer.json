{
  "name": "apparcherries/api",
  "description": "Archerries PHP API",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "firebase/php-jwt": "^6.10",
    "phpmailer/phpmailer": "^6.9",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "Archerries\\": "lib/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
