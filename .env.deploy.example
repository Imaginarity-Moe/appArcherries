REM Datei: .env.deploy
REM Wird von deploy.bat eingelesen. NICHT in Git committen.
REM Kopiere diese Datei zu ".env.deploy" und trage echte Werte ein.

set "FTP_HOST=home71821985.1and1-data.host"
set "FTP_USER=acc144056440"
set "FTP_PASS=<DEIN-FTP-PASSWORT>"

REM DocumentRoot der Subdomain archerries.mossig.de auf dem IONOS-FTP.
REM Bei Subdomain mit eigenem FTP-Account ist das oft "/". Wenn der gleiche
REM Account mehrere Sites bedient, z. B. "/archerries" oder "/clickandbuilds/archerries".
REM Im IONOS-Panel: "Domains & SSL" -> Subdomain bearbeiten -> Zielordner.
set "REMOTE_ROOT=/"
